####################################
# 🦎 KOMODO COMPOSE - VARIABLES 🦎 #
####################################

## Managed by Ansible - Do not edit manually!
## Generated on {{ ansible_date_time.iso8601 }}

## Stick to a specific version, or use `latest`
COMPOSE_KOMODO_IMAGE_TAG={{ komodo_config.compose_komodo_image_tag }}

## Backup config
COMPOSE_KOMODO_BACKUPS_PATH={{ komodo_config.backups_path }}

## DB credentials
KOMODO_DB_USERNAME={{ komodo_config.komodo_db_username }}
KOMODO_DB_PASSWORD={{ komodo_config.komodo_db_password }}

## Configure a secure passkey to authenticate between Core / Periphery.
KOMODO_PASSKEY={{ komodo_config.komodo_passkey }}

## Set your time zone for schedules
## https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ={{ komodo_config.timezone }}

#=-------------------------=#
#= Komodo Core Environment =#
#=-------------------------=#

## Used for Oauth / Webhook url suggestion / Caddy reverse proxy.
KOMODO_HOST={{ komodo_config.komodo_host }}
## Displayed in the browser tab.
KOMODO_TITLE={{ komodo_config.komodo_title }}
## Create a server matching this address as the "first server".
KOMODO_FIRST_SERVER={{ komodo_config.komodo_first_server }}
## Make all buttons just double-click, rather than the full confirmation dialog.
KOMODO_DISABLE_CONFIRM_DIALOG={{ komodo_config.komodo_disable_confirm_dialog | lower }}

## Rate Komodo polls your servers for status / container status / system stats / alerting.
KOMODO_MONITORING_INTERVAL="{{ komodo_config.komodo_monitoring_interval }}"
## Interval at which to poll Resources for any updates / automated actions.
KOMODO_RESOURCE_POLL_INTERVAL="{{ komodo_config.komodo_resource_poll_interval }}"

## Used to auth incoming webhooks.
KOMODO_WEBHOOK_SECRET={{ komodo_config.komodo_webhook_secret }}
## Used to generate jwt.
KOMODO_JWT_SECRET={{ komodo_config.komodo_jwt_secret }}
## Time to live for jwt tokens.
KOMODO_JWT_TTL="{{ komodo_config.komodo_jwt_ttl }}"

## Enable login with username + password.
KOMODO_LOCAL_AUTH={{ komodo_config.komodo_local_auth | lower }}
## Disable new user signups.
KOMODO_DISABLE_USER_REGISTRATION={{ komodo_config.komodo_disable_user_registration | lower }}
## All new logins are auto enabled
KOMODO_ENABLE_NEW_USERS={{ komodo_config.komodo_enable_new_users | lower }}
## Disable non-admins from creating new resources.
KOMODO_DISABLE_NON_ADMIN_CREATE={{ komodo_config.komodo_disable_non_admin_create | lower }}
## Allows all users to have Read level access to all resources.
KOMODO_TRANSPARENT_MODE={{ komodo_config.komodo_transparent_mode | lower }}

## Prettier logging with empty lines between logs
KOMODO_LOGGING_PRETTY={{ komodo_config.komodo_logging_pretty | lower }}
## More human readable logging of startup config (multi-line)
KOMODO_PRETTY_STARTUP_CONFIG={{ komodo_config.komodo_pretty_startup_config | lower }}

## OIDC Login
KOMODO_OIDC_ENABLED={{ komodo_config.komodo_oidc_enabled | lower }}
{% if komodo_config.komodo_oidc_enabled %}
{% if komodo_oidc_provider is defined %}
KOMODO_OIDC_PROVIDER={{ komodo_oidc_provider }}
{% endif %}
{% if komodo_oidc_redirect_host is defined %}
KOMODO_OIDC_REDIRECT_HOST={{ komodo_oidc_redirect_host }}
{% endif %}
{% if komodo_oidc_client_id is defined %}
KOMODO_OIDC_CLIENT_ID={{ komodo_oidc_client_id }}
{% endif %}
{% if komodo_oidc_client_secret is defined %}
KOMODO_OIDC_CLIENT_SECRET={{ komodo_oidc_client_secret }}
{% endif %}
{% if komodo_oidc_use_full_email is defined %}
KOMODO_OIDC_USE_FULL_EMAIL={{ komodo_oidc_use_full_email | lower }}
{% endif %}
{% if komodo_oidc_additional_audiences is defined %}
KOMODO_OIDC_ADDITIONAL_AUDIENCES={{ komodo_oidc_additional_audiences }}
{% endif %}
{% endif %}

## Github Oauth
KOMODO_GITHUB_OAUTH_ENABLED={{ komodo_config.komodo_github_oauth_enabled | lower }}
{% if komodo_config.komodo_github_oauth_enabled %}
KOMODO_GITHUB_OAUTH_ID={{ komodo_config.komodo_github_oauth_id }}
KOMODO_GITHUB_OAUTH_SECRET={{ komodo_config.komodo_github_oauth_secret }}
{% endif %}

## Google Oauth
KOMODO_GOOGLE_OAUTH_ENABLED={{ komodo_config.komodo_google_oauth_enabled | lower }}
{% if komodo_config.komodo_google_oauth_enabled %}
KOMODO_GOOGLE_OAUTH_ID={{ komodo_config.komodo_google_oauth_id }}
KOMODO_GOOGLE_OAUTH_SECRET={{ komodo_config.komodo_google_oauth_secret }}
{% endif %}

## AWS - Used to launch Builder instances.
KOMODO_AWS_ACCESS_KEY_ID={{ komodo_config.komodo_aws_access_key_id }}
KOMODO_AWS_SECRET_ACCESS_KEY={{ komodo_config.komodo_aws_secret_access_key }}

#=------------------------------=#
#= Komodo Periphery Environment =#
#=------------------------------=#

## Specify the root directory used by Periphery agent.
PERIPHERY_ROOT_DIRECTORY={{ komodo_config.periphery_root_directory }}

## Periphery passkeys must include KOMODO_PASSKEY to authenticate.
PERIPHERY_PASSKEYS={{ komodo_config.komodo_passkey }}

## Specify whether to disable the terminals feature
## and disallow remote shell access (inside the Periphery container).
PERIPHERY_DISABLE_TERMINALS={{ komodo_config.periphery_disable_terminals | lower }}

## Enable SSL using self signed certificates.
## Connect to Periphery at https://address:8120.
PERIPHERY_SSL_ENABLED={{ komodo_config.periphery_ssl_enabled | lower }}

## If the disk size is overreporting, can use one of these to 
## whitelist / blacklist the disks to filter them, whichever is easier.
## Accepts comma separated list of paths.
## Usually whitelisting just /etc/hostname gives correct size
PERIPHERY_INCLUDE_DISK_MOUNTS={{ komodo_config.periphery_include_disk_mounts }}
{% if komodo_config.periphery_exclude_disk_mounts is defined %}
PERIPHERY_EXCLUDE_DISK_MOUNTS={{ komodo_config.periphery_exclude_disk_mounts }}
{% endif %}

## Prettier logging with empty lines between logs
PERIPHERY_LOGGING_PRETTY={{ komodo_config.periphery_logging_pretty | lower }}
## More human readable logging of startup config (multi-line)
PERIPHERY_PRETTY_STARTUP_CONFIG={{ komodo_config.periphery_pretty_startup_config | lower }}