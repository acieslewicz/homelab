####################################
# 🦎 KOMODO COMPOSE - VARIABLES 🦎 #
####################################

## Managed by Ansible - Do not edit manually!
## Generated on {{ ansible_date_time.iso8601 }}

COMPOSE_KOMODO_IMAGE_TAG={{ version }}

COMPOSE_KOMODO_BACKUPS_PATH={{ backups_path }}

KOMODO_DB_USERNAME={{ db_username }}
KOMODO_DB_PASSWORD={{ db_password }}

KOMODO_PASSKEY={{ komodo_passkey }}

TZ={{ timezone }}

#=-------------------------=#
#= Komodo Core Environment =#
#=-------------------------=#

KOMODO_HOST={{ host }}
KOMODO_TITLE={{ title }}
KOMODO_FIRST_SERVER={{ komodo_first_server }}
KOMODO_DISABLE_CONFIRM_DIALOG={{ disable_confirm_dialog | lower }}

KOMODO_MONITORING_INTERVAL="{{ monitoring_interval }}"
KOMODO_RESOURCE_POLL_INTERVAL="{{ resource_poll_interval }}"

KOMODO_WEBHOOK_SECRET={{ webhook_secret }}
KOMODO_JWT_SECRET={{ jwt_secret }}
KOMODO_JWT_TTL="{{ jwt_ttl }}"

KOMODO_LOCAL_AUTH={{ local_auth | lower }}
KOMODO_DISABLE_USER_REGISTRATION={{ disable_user_registration | lower }}
KOMODO_ENABLE_NEW_USERS={{ enable_new_users | lower }}
KOMODO_DISABLE_NON_ADMIN_CREATE={{ disable_non_admin_create | lower }}
KOMODO_TRANSPARENT_MODE={{ transparent_mode | lower }}

KOMODO_LOGGING_PRETTY={{ logging_pretty | lower }}
KOMODO_PRETTY_STARTUP_CONFIG={{ pretty_startup_config | lower }}

KOMODO_OIDC_ENABLED={{ oidc_enabled | lower }}
{% if oidc_enabled %}
{% if oidc_provider is defined %}
KOMODO_OIDC_PROVIDER={{ oidc_provider }}
{% endif %}
{% if oidc_redirect_host is defined %}
KOMODO_OIDC_REDIRECT_HOST={{ oidc_redirect_host }}
{% endif %}
{% if oidc_client_id is defined %}
KOMODO_OIDC_CLIENT_ID={{ oidc_client_id }}
{% endif %}
{% if oidc_client_secret is defined %}
KOMODO_OIDC_CLIENT_SECRET={{ oidc_client_secret }}
{% endif %}
{% if oidc_use_full_email is defined %}
KOMODO_OIDC_USE_FULL_EMAIL={{ oidc_use_full_email | lower }}
{% endif %}
{% if oidc_additional_audiences is defined %}
KOMODO_OIDC_ADDITIONAL_AUDIENCES={{ oidc_additional_audiences }}
{% endif %}
{% endif %}

## Github Oauth
KOMODO_GITHUB_OAUTH_ENABLED={{ github_oauth_enabled | lower }}
{% if github_oauth_enabled %}
KOMODO_GITHUB_OAUTH_ID={{ github_oauth_id }}
KOMODO_GITHUB_OAUTH_SECRET={{ github_oauth_secret }}
{% endif %}

## Google Oauth
KOMODO_GOOGLE_OAUTH_ENABLED={{ google_oauth_enabled | lower }}
{% if google_oauth_enabled %}
KOMODO_GOOGLE_OAUTH_ID={{ google_oauth_id }}
KOMODO_GOOGLE_OAUTH_SECRET={{ google_oauth_secret }}
{% endif %}

## AWS - Used to launch Builder instances.
KOMODO_AWS_ACCESS_KEY_ID={{ aws_access_key_id }}
KOMODO_AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key }}
